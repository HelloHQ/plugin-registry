{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HelloHQ/plugin-registry/schema/manifest.schema.json",
  "title": "HelloHQ Plugin Manifest",
  "description": "One manifest.json per plugin lives at plugins/<id>/manifest.json. Validated by registry CI on every PR.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "description",
    "author",
    "author_url",
    "repo",
    "license",
    "min_host_version",
    "wasm_url",
    "content_hash_sha256",
    "permissions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Reverse-domain identifier. Frozen at first submission. The 'hellohq.' prefix is reserved for Official plugins.",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9][a-z0-9-]*)+$",
      "maxLength": 128
    },
    "name": { "type": "string", "maxLength": 60 },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$"
    },
    "description": { "type": "string", "maxLength": 200 },
    "author": { "type": "string", "minLength": 1 },
    "author_url": { "type": "string", "format": "uri" },
    "repo": { "type": "string", "format": "uri" },
    "license": { "type": "string", "minLength": 1 },
    "categories": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "enum": [
          "analytics",
          "import",
          "export",
          "productivity",
          "finance",
          "reporting",
          "utilities",
          "charts",
          "integration"
        ]
      }
    },
    "min_host_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "execution_mode": {
      "enum": ["wasm", "sidecar"],
      "default": "wasm",
      "description": "sidecar (Tier 1 Python) requires trust_tier: verified and is desktop-only."
    },
    "network": {
      "type": "object",
      "description": "v2. Required when permissions includes network:fetch.",
      "additionalProperties": false,
      "properties": {
        "allowed_origins": {
          "type": "array",
          "maxItems": 10,
          "items": { "type": "string", "format": "uri" }
        }
      }
    },
    "wasm_url": { "type": "string", "format": "uri" },
    "content_hash_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Lowercase hex SHA-256 of the file at wasm_url. Verified by CI and by the app before every execution."
    },
    "ui_bundle_url": { "type": "string", "format": "uri" },
    "ui_bundle_hash_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "ui_type": {
      "enum": ["declarative", "webview", "headless"],
      "default": "declarative"
    },
    "sidebar_icon": {
      "type": "string",
      "description": "24x24 single-fill SVG (URL for wasm plugins, bundle path for webview). Invalid icons fall back to a generic glyph."
    },
    "entry_function": { "type": "string", "default": "run" },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "enum": [
              "read:portfolio_names",
              "read:sheet_structure",
              "read:asset_count",
              "read:currency_rates",
              "read:aggregated_values",
              "write:external_output",
              "read:external_input",
              "plugin:storage",
              "network:fetch",
              "ai:inference"
            ]
          },
          "scope": { "type": "object" }
        },
        "required": ["id"]
      }
    },
    "trust_tier": {
      "enum": ["community", "verified", "official"],
      "description": "Assigned by the registry team at merge — do not set this yourself. Governs which capabilities the plugin may declare. community (default): Wasm-only, declarative/headless UI, no ai:inference, no write:external_output, no sidecar. verified: unlocks sidecar execution, ai:inference, write:external_output, and webview UI after manual Verified review. official: HelloHQ first-party plugins (hellohq.* id prefix)."
    },
    "provenance": {
      "enum": ["core", "community", "enterprise"],
      "default": "community",
      "description": "Who built the plugin. 'core' is reserved for HelloHQ (requires an official signature) and is rejected from outside authors by CI. 'enterprise' is private to the org that built it and MUST NOT appear in the public registry — CI rejects it (see REVIEW_POLICY). Defaults to community."
    },
    "licensing": {
      "type": "object",
      "additionalProperties": false,
      "description": "Open-source vs commercial status. Surfaced as a badge in the in-app Plugin Browser so users see licensing before installing.",
      "properties": {
        "kind": { "enum": ["open_source", "commercial"], "default": "open_source" },
        "spdx": {
          "type": "string",
          "description": "SPDX licence identifier for open-source plugins, e.g. MIT, Apache-2.0."
        },
        "product_id": {
          "type": "string",
          "description": "HelloHQ-brokered marketplace SKU. Required when kind == commercial."
        },
        "price_cents": { "type": "integer", "minimum": 0 },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$", "default": "USD" },
        "pricing_model": { "enum": ["one_time", "subscription"] },
        "info_url": { "type": "string", "format": "uri" }
      }
    },
    "publisher_signing_key_id": {
      "type": "string",
      "description": "Assigned by the registry team at merge. Omit on first submission."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "ui_type": { "const": "webview" } } },
      "then": { "required": ["ui_bundle_url", "ui_bundle_hash_sha256"] }
    },
    {
      "$comment": "read:aggregated_values requires an explicit portfolio scope.",
      "if": {
        "properties": {
          "permissions": {
            "contains": { "properties": { "id": { "const": "read:aggregated_values" } }, "required": ["id"] }
          }
        }
      },
      "then": {
        "properties": {
          "permissions": {
            "contains": {
              "properties": {
                "id": { "const": "read:aggregated_values" },
                "scope": { "type": "object", "required": ["portfolios"] }
              },
              "required": ["id", "scope"]
            }
          }
        }
      }
    },
    {
      "$comment": "Commercial plugins must carry a HelloHQ-brokered marketplace SKU.",
      "if": {
        "properties": {
          "licensing": {
            "properties": { "kind": { "const": "commercial" } },
            "required": ["kind"]
          }
        },
        "required": ["licensing"]
      },
      "then": {
        "properties": {
          "licensing": { "required": ["product_id"] }
        }
      }
    }
  ]
}
